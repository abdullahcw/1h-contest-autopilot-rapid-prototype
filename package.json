{
  "name": "ohadmin-client",
  "version": "3.3.1",
  "engines": { "node": "22.x" },
  "scripts": {
    "build": "ng build --configuration production",
    "ng-high-memory": "node --max_old_space_size=8000 ./node_modules/@angular/cli/bin/ng",
    "start": "node --max_old_space_size=8000 ./node_modules/@angular/cli/bin/ng serve",
    "ng": "ng",
    "zip-build": "node --max_old_space_size=8000 ./node_modules/@angular/cli/bin/ng build --configuration production && gzipper compress ./dist/OHAdminClient",
    "zip-build1": "ng build --configuration production && gzipper compress --exclude assets ./dist/OHAdminClient",
    "zip-build2": "ng build --configuration production && gzipper compress ./dist/OHAdminClient ./dist/OHAdminClient-gzip",
    "test": "node --max_old_space_size=8000 ./node_modules/@angular/cli/bin/ng test --source-map=false",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "gzipper": "gzipper",
    "gzip1": "gzipper compress ./dist/OHAdminClient ./dist/OHAdminClient-gzip",
    "gzip": "gzipper compress --verbose --output-file-format [filename].[ext] ./dist/OHAdminClient ./dist/OHAdminClient-gzip"
  },
  "private": true,
  "dependencies": {
    "@angular-slider/ngx-slider": "^2.0.3",
